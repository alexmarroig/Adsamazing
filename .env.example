NODE_ENV=development

# API
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ads_autopilot?schema=public
REDIS_URL=redis://localhost:6379

# Supabase JWT secret for API auth
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Google Ads OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/google/oauth/callback
GOOGLE_DEVELOPER_TOKEN=your-google-developer-token
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/adwords https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# 32 bytes base64
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# AI
OPENAI_API_KEY=

# Workers
ENABLE_SCRAPING_CONNECTOR=false

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

